# ─── Gemini ───────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── Google Maps (browser-exposed) ────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-js-api-key

# ─── Google Cloud / Firebase Admin (server) ───────────────
GOOGLE_CLOUD_PROJECT_ID=civicpulse-xxxxx
FIREBASE_PROJECT_ID=civicpulse-xxxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@civicpulse-xxxxx.iam.gserviceaccount.com
# Paste the full private key. Keep the \n escapes if your shell needs them.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: path to a service-account JSON used by @google-cloud/language & pubsub.
# If unset, those libs fall back to the FIREBASE_* admin creds above.
GOOGLE_APPLICATION_CREDENTIALS=

# ─── Firebase Web SDK (browser-exposed, single JSON string) ─
NEXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"...","authDomain":"civicpulse-xxxxx.firebaseapp.com","projectId":"civicpulse-xxxxx","storageBucket":"civicpulse-xxxxx.appspot.com","messagingSenderId":"...","appId":"..."}

# Optional: FCM Web Push VAPID key
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ─── Pub/Sub ──────────────────────────────────────────────
PUBSUB_TOPIC_NEW_ISSUES=new-issues

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Default city center (Indore)
NEXT_PUBLIC_DEFAULT_LAT=22.7196
NEXT_PUBLIC_DEFAULT_LNG=75.8577
